# Garmin Connect credentials
GARMIN_EMAIL=         # Your Garmin Connect login email
GARMIN_PASSWORD=      # Your Garmin Connect login password
GARMIN_TOKEN_DIR=~/.garminconnect  # Directory for persisted OAuth tokens

# Supabase connection
SUPABASE_URL=         # Supabase Dashboard -> Settings -> API -> Project URL
SUPABASE_KEY=         # Supabase Dashboard -> Settings -> API -> anon/public or service_role key

# Pipeline settings
TARGET_TIMEZONE=Europe/Berlin  # Timezone for scheduling and date normalization
LOG_JSON=false                 # Set to true for JSON-formatted logs in production

# Email delivery (Resend)
RESEND_API_KEY=               # Resend Dashboard -> API Keys
SENDER_EMAIL=                 # Verified sender email
RECIPIENT_EMAIL=              # Where to receive daily protocols

# AI analysis
ANTHROPIC_API_KEY=            # Anthropic Console -> API Keys

# WhatsApp delivery (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=        # Meta Business > WhatsApp > API Setup > Temporary/Permanent token
WHATSAPP_PHONE_NUMBER_ID=     # Meta Business > WhatsApp > API Setup > Phone number ID
WHATSAPP_RECIPIENT_PHONE=     # Your phone number in international format, e.g. +491701234567
