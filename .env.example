# Garmin Connect credentials
GARMIN_EMAIL=         # Your Garmin Connect login email
GARMIN_PASSWORD=      # Your Garmin Connect login password
GARMIN_TOKEN_DIR=~/.garminconnect  # Directory for persisted OAuth tokens

# Supabase connection
SUPABASE_URL=         # Supabase Dashboard -> Settings -> API -> Project URL
SUPABASE_KEY=         # Supabase Dashboard -> Settings -> API -> anon/public or service_role key

# Pipeline settings
TARGET_TIMEZONE=Europe/Berlin  # Timezone for scheduling and date normalization
LOG_JSON=false                 # Set to true for JSON-formatted logs in production
